#!/bin/bash
# Mail Address Verifier - Setup Script

set -e

APP_DIR="/opt/mail-address-verifier"
VENV_DIR="$APP_DIR/venv"

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
CYAN='\033[0;36m'
NC='\033[0m'

log_info() { echo -e "${GREEN}[OK]${NC} $1"; }
log_warn() { echo -e "${YELLOW}[WARN]${NC} $1"; }
log_error() { echo -e "${RED}[ERROR]${NC} $1"; }
log_step() { echo -e "${CYAN}[STEP]${NC} $1"; }

echo ""
echo -e "${CYAN}================================================${NC}"
echo -e "${CYAN}  Mail Address Verifier - Setup Script${NC}"
echo -e "${CYAN}================================================${NC}"
echo ""

cd "$APP_DIR"

# --- Check root ---
if [ "$EUID" -ne 0 ]; then
    log_error "Please run as root (sudo ./setup.sh)"
    exit 1
fi

# --- .env ---
log_step "Checking configuration..."
if [ ! -f ".env" ]; then
    if [ -f ".env.example" ]; then
        cp .env.example .env
        log_info ".env file created from template"
        echo ""
        log_warn "IMPORTANT: Edit .env file with your credentials:"
        echo "   - IMAP/SMTP settings"
        echo "   - Database password"
        echo "   - API keys (Claude/OpenAI/Perplexity)"
        echo ""
    else
        log_error ".env.example not found"
        exit 1
    fi
else
    log_info ".env file already exists"
fi

# --- System dependencies ---
log_step "Installing system dependencies..."
apt-get update -qq

PACKAGES=(
    python3-full
    python3-pip
    python3-venv
    python3-dev
    libxml2-dev
    libxslt1-dev
    libffi-dev
    libcairo2-dev
    libpango1.0-dev
    libgdk-pixbuf2.0-dev
    build-essential
    pkg-config
    default-libmysqlclient-dev
    lsof
    curl
)

apt-get install -y -qq "${PACKAGES[@]}" > /dev/null 2>&1
log_info "System dependencies installed"

# --- Python venv ---
log_step "Setting up Python virtual environment..."
if [ -d "$VENV_DIR" ]; then
    log_warn "Virtual environment exists, recreating..."
    rm -rf "$VENV_DIR"
fi

python3 -m venv "$VENV_DIR"
source "$VENV_DIR/bin/activate"

# Upgrade pip
pip install --upgrade pip setuptools wheel --quiet
log_info "Virtual environment created at $VENV_DIR"

# --- Python dependencies ---
log_step "Installing Python dependencies..."
if [ -f "requirements.txt" ]; then
    # Backup and fix requirements for compatibility
    cp requirements.txt requirements.txt.bak 2>/dev/null || true

    # Remove strict version pins that may cause issues
    sed -i 's/==/>=/g' requirements.txt

    pip install -r requirements.txt --quiet 2>/dev/null || {
        log_warn "Some packages failed, retrying with less strict versions..."
        pip install -r requirements.txt --quiet --ignore-installed
    }

    # Restore original
    mv requirements.txt.bak requirements.txt 2>/dev/null || true
    log_info "Python dependencies installed"
else
    log_error "requirements.txt not found"
    exit 1
fi

# --- Create directories ---
log_step "Creating directories..."
mkdir -p logs data/attachments data/reports
touch logs/.gitkeep data/attachments/.gitkeep data/reports/.gitkeep
log_info "Directories created"

# --- Make scripts executable ---
log_step "Setting up scripts..."
chmod +x "$APP_DIR"/*.sh 2>/dev/null || true
log_info "Scripts are now executable"

# --- Create convenience symlinks ---
if [ ! -L "/usr/local/bin/mail-verifier" ]; then
    ln -sf "$APP_DIR/start.sh" /usr/local/bin/mail-verifier-start
    ln -sf "$APP_DIR/stop.sh" /usr/local/bin/mail-verifier-stop
    ln -sf "$APP_DIR/status.sh" /usr/local/bin/mail-verifier-status
    log_info "Convenience commands created (mail-verifier-start/stop/status)"
fi

echo ""
echo -e "${CYAN}================================================${NC}"
echo -e "${GREEN}  Setup complete!${NC}"
echo -e "${CYAN}================================================${NC}"
echo ""
echo "Next steps:"
echo ""
echo "  1. Edit configuration (if needed):"
echo "     nano $APP_DIR/.env"
echo ""
echo "  2. Start manually:"
echo "     cd $APP_DIR && ./start.sh"
echo ""
echo "  3. OR install as systemd service (recommended for production):"
echo "     cd $APP_DIR && ./install-service.sh"
echo ""
echo "     This will:"
echo "     - Start the service automatically on boot"
echo "     - Restart on failures"
echo "     - Manage via systemctl commands"
echo ""
echo "  4. Access dashboard:"
echo "     http://localhost:8080"
echo ""
echo "Available commands:"
echo "  ./start.sh           - Start application"
echo "  ./stop.sh            - Stop application"
echo "  ./restart.sh         - Restart application"
echo "  ./status.sh          - Check status"
echo "  ./logs.sh            - View logs"
echo "  ./install-service.sh - Install as systemd service"
echo ""
