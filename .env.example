# IMAP Configuration
IMAP_HOST=imap.example.com
IMAP_PORT=993
IMAP_USER=your-email@example.com
IMAP_PASSWORD=your-password
IMAP_FOLDER=INBOX
IMAP_CHECK_INTERVAL=60
IMAP_SEARCH_MODE=unseen
IMAP_VERIFIED_FOLDER=Verified
IMAP_MOVE_TO_VERIFIED=true

# SMTP Configuration (for sending reports)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your-email@example.com
SMTP_PASSWORD=your-password
SMTP_FROM=noreply@example.com

# Database Configuration
DB_HOST=localhost
DB_PORT=3306
DB_NAME=mail_verifier
DB_USER=root
DB_PASSWORD=your-db-password

# AI Provider Configuration
# Choose 'openai', 'claude', or 'perplexity'
AI_PROVIDER=claude

# OpenAI API (GPT-4/GPT-5/O1)
OPENAI_API_KEY=your-openai-api-key

# Model selection:
# - gpt-4-turbo-preview: Fast, accurate (recommended for production)
# - gpt-4o: Latest GPT-4 Optimized
# - o1-preview: Deep reasoning model (slower but more thorough)
# - o1-mini: Faster reasoning model
# - gpt-5: When available
OPENAI_MODEL=o1-preview

OPENAI_MAX_TOKENS=4000
OPENAI_TEMPERATURE=0.3

# Deep Research Mode
# Enable multi-pass analysis for extremely thorough investigation
OPENAI_DEEP_RESEARCH=true
# Number of analysis passes (1-3 recommended, more = slower but deeper)
# 1 = Single pass
# 2 = Initial analysis + deep refinement (recommended)
# 3 = Initial + 2 refinement passes (maximum depth)
OPENAI_RESEARCH_STEPS=2

# Claude API (alternative)
ANTHROPIC_API_KEY=your-anthropic-api-key
CLAUDE_MODEL=claude-3-5-sonnet-20241022
CLAUDE_MAX_TOKENS=4000

# Perplexity API (alternative with online search capabilities)
PERPLEXITY_API_KEY=your-perplexity-api-key
# Available models:
# - sonar (lightweight, cost-effective, online search)
# - sonar-pro (advanced, complex queries, online search)
# - sonar-reasoning (fast reasoning with online search)
# - sonar-reasoning-pro (precise reasoning powered by DeepSeek-R1)
PERPLEXITY_MODEL=sonar-pro
PERPLEXITY_MAX_TOKENS=4000

# Custom Perplexity Analysis Prompt (optional)
# Leave empty to use default prompt. You can use placeholders:
# {from_address}, {from_name}, {subject}, {domain}, {domain_age_days},
# {sender_ip}, {dkim_valid}, {spf_valid}, {dmarc_valid}, {ip_blacklisted}, {is_proxy}, {geolocation}
PERPLEXITY_ANALYSIS_PROMPT=

# Custom Analysis Prompt (optional - leave empty to use default deep research prompt)
# You can provide a custom system prompt here for specialized analysis
ANALYSIS_PROMPT_TEMPLATE=

# Web Admin
WEB_HOST=0.0.0.0
WEB_PORT=8080
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme

# Application Settings
LOG_LEVEL=INFO
MAX_WORKERS=5
REPORT_LANGUAGE=ru
TIMEZONE=Europe/Kyiv
